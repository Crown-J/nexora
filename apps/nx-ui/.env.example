# Next.js 前端環境變數

# 執行模式（建置時寫入）
# - development 或未設定：真實登入 POST /auth/login、GET /auth/me，需後端 + DATABASE_URL
# - demo：離線展示；登入與 session 短路，不接資料庫（給客戶手機 demo 用）
NEXT_PUBLIC_NEXORA_RUN_MODE=development

# 後端 API base URL（瀏覽器可存取）
# - 本機開發通常是 http://localhost:3001 或反向代理位址
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# NX00-API-001：前端 API client 讀取的變數名稱
NEXT_PUBLIC_API_URL=http://localhost:3001

# demo 模式可不設 NEXT_PUBLIC_API_URL（非登入的 API 呼叫會失敗，屬預期）；若需測半套串接可照填

# 認證 / 其他前端用設定可在此擴充
# 例如：
# NEXT_PUBLIC_APP_ENV=dev

