# 伺服器基本設定
NODE_ENV=development
PORT=3001  # 後端 API 服務對外 port，可依需要調整

# =============================================================================
# 資料庫（db-core / Prisma + @prisma/adapter-pg）
# =============================================================================
# Supabase：請用 Dashboard → Database → ORM／Connection pooling 提供的 **Transaction**
# pooler URI（6543），與 packages/db-core/.env 的 DATABASE_URL 一致。
#
# 使用者名稱須為 postgres.[project-ref]（不可只寫 postgres），並加上 ?pgbouncer=true，
# 否則 pooler 常回報 Tenant or user not found。
#
# migrate / seed 的 DIRECT_URL 只在 packages/db-core/.env 設定；nx-api 不需要。
#
# 複製為 .env，將 [project-ref]、[password]、pooler 主機改為專案實際值。
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 選用：本機 Docker / 自建 Postgres
# DATABASE_URL="postgresql://nexora:請填入資料庫密碼@localhost:5432/nexora_core?schema=public"

# =============================================================================
# JWT
# =============================================================================
# 本機整合測試請與 packages/db-core prisma seed 的帳密一致（例如 DEV 種子預設密碼 changeme）；
# 正式環境務必使用強隨機 JWT_SECRET 與安全密碼策略。
JWT_SECRET=請填入任意安全隨機字串
JWT_EXPIRES_IN=8h  # token 有效期（建議 8h = 一個工作天）
