# 伺服器基本設定
NODE_ENV=development
PORT=3001  # 後端 API 服務對外 port，可依需要調整

# =============================================================================
# 資料庫（db-core / Prisma + @prisma/adapter-pg）
# =============================================================================
# 本機開發預設使用 Docker PostgreSQL（見 infra/docker/docker-compose.yml）：
#   docker compose -f infra/docker/docker-compose.yml up -d
#
# 與 packages/db-core/.env 的 DATABASE_URL 必須指向同一資料庫。
# migrate / seed 請在 packages/db-core 設定 DIRECT_URL（見該目錄 .env.example）。
# =============================================================================
DATABASE_URL="postgresql://nexora:nexora123@localhost:5433/nexora_core?schema=public"

# =============================================================================
# JWT
# =============================================================================
# 本機整合測試請與 packages/db-core prisma seed 的帳密一致（例如 DEV 種子預設密碼 changeme）；
# 正式環境務必使用強隨機 JWT_SECRET 與安全密碼策略。
JWT_SECRET=請填入任意安全隨機字串
JWT_EXPIRES_IN=8h  # token 有效期（建議 8h = 一個工作天）
