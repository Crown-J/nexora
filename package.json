  "dependencies": {
    "@prisma/client": "^7.4.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "prisma": "^7.4.0",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  }
}
