{
  "name": "nexora-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
