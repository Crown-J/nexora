# =============================================================================
# db-core / Prisma — 本機 Docker PostgreSQL（與 infra/docker/docker-compose.yml 一致）
# =============================================================================
# 1) 啟動資料庫：於 repo 根目錄執行
#    docker compose -f infra/docker/docker-compose.yml up -d
# 2) 複製本檔為 packages/db-core/.env
#
# 預設：使用者 nexora、密碼 nexora123、資料庫 nexora_core、主機埠 5433（對應容器內 5432）
# 本機無 PgBouncer：migrate / seed / 執行期可共用同一 URI；Prisma CLI 仍優先讀 DIRECT_URL。
# =============================================================================

DATABASE_URL="postgresql://nexora:nexora123@localhost:5433/nexora_core?schema=public"
DIRECT_URL="postgresql://nexora:nexora123@localhost:5433/nexora_core?schema=public"

# apps/nx-api 的 DATABASE_URL 請與上列 DATABASE_URL 一致（見 apps/nx-api/.env.example）。
