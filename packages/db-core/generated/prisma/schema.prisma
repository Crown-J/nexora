  seats                  Int
  startAt                DateTime     @map("start_at")
  endAt                  DateTime     @map("end_at")
  autoRenew              Boolean      @map("auto_renew")
  baseFeeSnapshot        Int          @map("base_fee_snapshot")
  seatFeeSnapshot        Int          @map("seat_fee_snapshot")
  discountTypeSnapshot   String       @map("discount_type_snapshot") @db.VarChar(1)
  discountValueSnapshot  Int          @map("discount_value_snapshot")
  subtotalSnapshot       Int          @map("subtotal_snapshot")
  discountAmountSnapshot Int          @map("discount_amount_snapshot")
  totalSnapshot          Int          @map("total_snapshot")
  /// 幣別（外鍵 → nx00_currency；長度對齊 PK VARCHAR(15)）
  currencyId             String       @map("currency_id") @db.VarChar(15)
  currency               Nx00Currency @relation(fields: [currencyId], references: [id])
  remark                 String?      @db.VarChar(200)
  createdAt              DateTime     @default(now()) @map("created_at")
  createdBy              String?      @map("created_by") @db.VarChar(15)
  updatedAt              DateTime     @updatedAt @map("updated_at")
  updatedBy              String?      @map("updated_by") @db.VarChar(15)

  tenant Nx99Tenant             @relation(fields: [tenantId], references: [id])
  plan   Nx99Plan               @relation(fields: [planId], references: [id])
  items  Nx99SubscriptionItem[]

  @@map("nx99_subscription")
}

/// =======================================================
/// NX99 - SubscriptionItem
/// Table: nx99_subscription_item
/// =======================================================
model Nx99SubscriptionItem {
  /// NX99 訂閱項目明細 - 記錄標配/加購模組與價格快照
  id                    String   @id @default(dbgenerated("gen_nx99_suit_id()")) @db.VarChar(15)
  subscriptionId        String   @map("subscription_id") @db.VarChar(15)
  itemType              String   @map("item_type") @db.VarChar(20)
  refId                 String   @map("ref_id") @db.VarChar(15)
  status                String   @db.VarChar(20)
  isIncluded            Boolean  @map("is_included")
  billingCycle          String   @map("billing_cycle") @db.VarChar(1)
  priceSnapshot         Int      @map("price_snapshot")
  discountTypeSnapshot  String   @map("discount_type_snapshot") @db.VarChar(1)
  discountValueSnapshot Int      @map("discount_value_snapshot")
  totalSnapshot         Int      @map("total_snapshot")
  startAt               DateTime @map("start_at")
  endAt                 DateTime @map("end_at")
  createdAt             DateTime @default(now()) @map("created_at")
  createdBy             String?  @map("created_by") @db.VarChar(15)
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedBy             String?  @map("updated_by") @db.VarChar(15)

  subscription Nx99Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("nx99_subscription_item")
}

/// =======================================================
/// NX99 - ProductModule
/// Table: nx99_product_module
/// =======================================================
model Nx99ProductModule {
  /// NX99 產品模組主檔 - 定義可銷售的 SKU
  id                 String   @id @default(dbgenerated("gen_nx99_prmo_id()")) @db.VarChar(15)
  code               String   @unique @db.VarChar(30)
  name               String   @db.VarChar(100)
  moduleLevel        String   @map("module_level") @db.VarChar(1)
  applicablePlanCode String   @map("applicable_plan_code") @db.VarChar(30)
  billingType        String   @map("billing_type") @db.VarChar(1)
  monthlyFee         Int      @map("monthly_fee")
  isBundleDefault    Boolean  @map("is_bundle_default")
  description        String?
  sortNo             Int      @map("sort_no")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  createdBy          String?  @map("created_by") @db.VarChar(15)
  updatedAt          DateTime @updatedAt @map("updated_at")
  updatedBy          String?  @map("updated_by") @db.VarChar(15)

  moduleMaps Nx99ProductModuleMap[]

  @@map("nx99_product_module")
}

/// =======================================================
/// NX99 - ProductModuleMap
/// Table: nx99_product_module_map
/// =======================================================
model Nx99ProductModuleMap {
  /// NX99 模組對照表 - 將 SKU 對應到程式碼模組 NX00~NX06
  id              String   @id @default(dbgenerated("gen_nx99_prmm_id()")) @db.VarChar(15)
  productModuleId String   @map("product_module_id") @db.VarChar(15)
  appModuleCode   String   @map("app_module_code") @db.VarChar(10)
  isRequired      Boolean  @default(true) @map("is_required")
  remark          String?  @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String?  @map("created_by") @db.VarChar(15)
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedBy       String?  @map("updated_by") @db.VarChar(15)

  productModule Nx99ProductModule @relation(fields: [productModuleId], references: [id])

  @@map("nx99_product_module_map")
}
