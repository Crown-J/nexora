  voidedByUser  Nx00User?     @relation("Nx02InitVoidedBy", fields: [voidedBy], references: [id])

  items Nx02InitItem[]

  @@unique([tenantId, docNo])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
  @@map("nx02_init")
