// C:\nexora\packages\db-core\prisma\schema.prisma
// NEXORA / db-core schema
// - NX00 主檔欄位以 docs/nx00_field.csv（與計畫 NX00 欄位表）為準（Prisma camelCase；DB snake_case 用 @map）
// - Prisma 欄位 camelCase；DB 欄位 snake_case 用 @map 對應
// - 欄位說明：每個 scalar／關聯欄位上方使用 ///（Prisma doc）；PostgreSQL 以 migration COMMENT ON 寫入表／欄位備註（見 migrations/*_add_pg_comments_all）
// - ID 規則：VARCHAR(15) 由 DB DEFAULT gen_xxx_id() 產生
// - NX01～NX06：MW2 起逐步併回；目前含 **NX02 庫存**（對齊 docs/nx02_field.csv、MIG003）
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

/// 連線由執行環境之 `DATABASE_URL`／`DIRECT_URL` 提供（見 `prisma.config.ts` 與 `packages/db-core/.env.example`）；本機預設為 Docker PostgreSQL（`infra/docker/docker-compose.yml`）。
/// Prisma ORM 7 不支援於此區塊宣告 `url`／`directUrl`。
datasource db {
  provider = "postgresql"
}

/// =======================================================
/// NX00 - User
/// Table: nx00_user
/// =======================================================
/// 對齊 docs/nx00_field.csv（LITE）
model Nx00User {
  id         String     @id @default(dbgenerated("gen_nx00_user_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId   String     @map("tenant_id") @db.VarChar(15)
  tenant     Nx99Tenant @relation(fields: [tenantId], references: [id])
  /// 員工主檔 ID（外鍵，PRO；表未於 CSV 定義時可僅存 ID）
  employeeId String?    @map("employee_id") @db.VarChar(15)

  /// 登入帳號（DB：user_account）
  userAccount  String    @map("user_account") @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  /// 顯示名稱（DB：user_name）
  userName     String    @map("user_name") @db.VarChar(50)
  email        String?   @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  // self audit relations
  createdByUser Nx00User? @relation("Nx00UserCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00UserUpdatedBy", fields: [updatedBy], references: [id])

  createdUsers Nx00User[] @relation("Nx00UserCreatedBy")
  updatedUsers Nx00User[] @relation("Nx00UserUpdatedBy")

  // RBAC (UserRole / RoleView)
  userRoles Nx00UserRole[]

  /// 使用者可進出之倉庫／據點（nx00_user_warehouse）
  userWarehouses         Nx00UserWarehouse[]
  userWarehousesAssigned Nx00UserWarehouse[] @relation("Nx00UserWarehouseAssignedBy")

  // reverse relations (created/updated)
  rolesCreated Nx00Role[] @relation("Nx00RoleCreatedBy")
  rolesUpdated Nx00Role[] @relation("Nx00RoleUpdatedBy")
  viewsCreated Nx00View[] @relation("Nx00ViewCreatedBy")
  viewsUpdated Nx00View[] @relation("Nx00ViewUpdatedBy")

  partsCreated      Nx00Part[]      @relation("Nx00PartCreatedBy")
  partsUpdated      Nx00Part[]      @relation("Nx00PartUpdatedBy")
  partBrandsCreated Nx00PartBrand[] @relation("Nx00PartBrandCreatedBy")
  partBrandsUpdated Nx00PartBrand[] @relation("Nx00PartBrandUpdatedBy")
  carBrandsCreated  Nx00CarBrand[]  @relation("Nx00CarBrandCreatedBy")
  carBrandsUpdated  Nx00CarBrand[]  @relation("Nx00CarBrandUpdatedBy")
  partGroupsCreated Nx00PartGroup[] @relation("Nx00PartGroupCreatedBy")
  partGroupsUpdated Nx00PartGroup[] @relation("Nx00PartGroupUpdatedBy")
  warehousesCreated Nx00Warehouse[] @relation("Nx00WarehouseCreatedBy")
  warehousesUpdated Nx00Warehouse[] @relation("Nx00WarehouseUpdatedBy")
  locationsCreated  Nx00Location[]  @relation("Nx00LocationCreatedBy")
  locationsUpdated  Nx00Location[]  @relation("Nx00LocationUpdatedBy")
  partnersCreated   Nx00Partner[]   @relation("Nx00PartnerCreatedBy")
  partnersUpdated   Nx00Partner[]   @relation("Nx00PartnerUpdatedBy")

  // assignment/grant/revoke actors
  userRolesAssigned Nx00UserRole[] @relation("Nx00UserRoleAssignedBy")
  roleViewsGranted  Nx00RoleView[] @relation("Nx00RoleViewGrantedBy")
  roleViewsRevoked  Nx00RoleView[] @relation("Nx00RoleViewRevokedBy")

  // audit log actor
  auditLogs Nx00AuditLog[]

  bulletinsCreated      Nx00Bulletin[]      @relation("Nx00BulletinCreatedBy")
  bulletinsUpdated      Nx00Bulletin[]      @relation("Nx00BulletinUpdatedBy")
  calendarEventsCreated Nx00CalendarEvent[] @relation("Nx00CalendarEventCreatedBy")
  calendarEventsUpdated Nx00CalendarEvent[] @relation("Nx00CalendarEventUpdatedBy")

  countriesCreated      Nx00Country[]       @relation("Nx00CountryCreatedBy")
  countriesUpdated      Nx00Country[]       @relation("Nx00CountryUpdatedBy")
  currenciesCreated     Nx00Currency[]      @relation("Nx00CurrencyCreatedBy")
  currenciesUpdated     Nx00Currency[]      @relation("Nx00CurrencyUpdatedBy")
  brandCodeRulesCreated Nx00BrandCodeRule[] @relation("Nx00BrandCodeRuleCreatedBy")
  brandCodeRulesUpdated Nx00BrandCodeRule[] @relation("Nx00BrandCodeRuleUpdatedBy")
  partRelationsCreated  Nx00PartRelation[]  @relation("Nx00PartRelationCreatedBy")
  partRelationsUpdated  Nx00PartRelation[]  @relation("Nx00PartRelationUpdatedBy")

  nx02StockBalancesCreated      Nx02StockBalance[]      @relation("Nx02StockBalanceCreatedBy")
  nx02StockBalancesUpdated      Nx02StockBalance[]      @relation("Nx02StockBalanceUpdatedBy")
  nx02PartStockSettingsCreated  Nx02PartStockSetting[]  @relation("Nx02PartStockSettingCreatedBy")
  nx02PartStockSettingsUpdated  Nx02PartStockSetting[]  @relation("Nx02PartStockSettingUpdatedBy")
  nx02ShortagesCreated          Nx02Shortage[]          @relation("Nx02ShortageCreatedBy")
  nx02ShortagesUpdated          Nx02Shortage[]          @relation("Nx02ShortageUpdatedBy")
  nx02AutoReplenishesCreated    Nx02AutoReplenish[]     @relation("Nx02AutoReplenishCreatedBy")
  nx02AutoReplenishesUpdated    Nx02AutoReplenish[]     @relation("Nx02AutoReplenishUpdatedBy")
  nx02StockTakesCreated         Nx02StockTake[]         @relation("Nx02StockTakeCreatedBy")
  nx02StockTakesUpdated         Nx02StockTake[]         @relation("Nx02StockTakeUpdatedBy")
  nx02StockTakesPosted          Nx02StockTake[]         @relation("Nx02StockTakePostedBy")
  nx02StockTakesVoided          Nx02StockTake[]         @relation("Nx02StockTakeVoidedBy")
  nx02StockTakeItemsCreated     Nx02StockTakeItem[]     @relation("Nx02StockTakeItemCreatedBy")
  nx02StockTakeItemsUpdated     Nx02StockTakeItem[]     @relation("Nx02StockTakeItemUpdatedBy")
  nx02StockTransfersCreated     Nx02StockTransfer[]     @relation("Nx02StockTransferCreatedBy")
  nx02StockTransfersUpdated     Nx02StockTransfer[]     @relation("Nx02StockTransferUpdatedBy")
  nx02StockTransfersPosted      Nx02StockTransfer[]     @relation("Nx02StockTransferPostedBy")
  nx02StockTransfersVoided      Nx02StockTransfer[]     @relation("Nx02StockTransferVoidedBy")
  nx02StockTransferItemsCreated Nx02StockTransferItem[] @relation("Nx02StockTransferItemCreatedBy")
  nx02StockTransferItemsUpdated Nx02StockTransferItem[] @relation("Nx02StockTransferItemUpdatedBy")
  initsCreated                  Nx02Init[]              @relation("Nx02InitCreatedBy")
  initsUpdated                  Nx02Init[]              @relation("Nx02InitUpdatedBy")
  initsPosted                   Nx02Init[]              @relation("Nx02InitPostedBy")
  initsVoided                   Nx02Init[]              @relation("Nx02InitVoidedBy")
  initItemsCreated              Nx02InitItem[]          @relation("Nx02InitItemCreatedBy")
  initItemsUpdated              Nx02InitItem[]          @relation("Nx02InitItemUpdatedBy")

  @@unique([tenantId, userAccount])
  @@index([tenantId])
  @@map("nx00_user")
}

/// =======================================================
/// NX00 - Role
/// Table: nx00_role
/// =======================================================
model Nx00Role {
  id          String     @id @default(dbgenerated("gen_nx00_role_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId    String     @map("tenant_id") @db.VarChar(15)
  tenant      Nx99Tenant @relation(fields: [tenantId], references: [id])
  code        String     @db.VarChar(30)
  name        String     @db.VarChar(50)
  description String?    @db.VarChar(200)
  isSystem    Boolean    @default(false) @map("is_system")
  isActive    Boolean    @default(true) @map("is_active")
  sortNo      Int        @default(0) @map("sort_no")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00RoleCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00RoleUpdatedBy", fields: [updatedBy], references: [id])

  userRoles Nx00UserRole[]
  roleViews Nx00RoleView[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("nx00_role")
}

/// =======================================================
/// NX00 - UserRole
/// Table: nx00_user_role
/// =======================================================
model Nx00UserRole {
  id       String     @id @default(dbgenerated("gen_nx00_user_role_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId String     @map("tenant_id") @db.VarChar(15)
  tenant   Nx99Tenant @relation(fields: [tenantId], references: [id])
  userId   String     @map("user_id") @db.VarChar(15)
  roleId   String     @map("role_id") @db.VarChar(15)

  isPrimary  Boolean   @default(false) @map("is_primary")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by") @db.VarChar(15)
  revokedAt  DateTime? @map("revoked_at")
  isActive   Boolean   @default(true) @map("is_active")

  user           Nx00User  @relation(fields: [userId], references: [id])
  role           Nx00Role  @relation(fields: [roleId], references: [id])
  assignedByUser Nx00User? @relation("Nx00UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([isActive])
  @@map("nx00_user_role")
}

/// =======================================================
/// NX00 - UserWarehouse（使用者據點對應）
/// Table: nx00_user_warehouse
/// =======================================================
model Nx00UserWarehouse {
  id          String     @id @default(dbgenerated("gen_nx00_user_warehouse_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId    String     @map("tenant_id") @db.VarChar(15)
  tenant      Nx99Tenant @relation(fields: [tenantId], references: [id])
  userId      String     @map("user_id") @db.VarChar(15)
  warehouseId String     @map("warehouse_id") @db.VarChar(15)

  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by") @db.VarChar(15)
  revokedAt  DateTime? @map("revoked_at")
  isActive   Boolean   @default(true) @map("is_active")

  user           Nx00User      @relation(fields: [userId], references: [id])
  warehouse      Nx00Warehouse @relation(fields: [warehouseId], references: [id])
  assignedByUser Nx00User?     @relation("Nx00UserWarehouseAssignedBy", fields: [assignedBy], references: [id])

  @@unique([tenantId, userId, warehouseId])
  @@index([tenantId])
  @@index([userId])
  @@index([warehouseId])
  @@index([isActive])
  @@map("nx00_user_warehouse")
}

/// =======================================================
/// NX00 - View
/// Table: nx00_view
/// =======================================================
model Nx00View {
  id         String  @id @default(dbgenerated("gen_nx00_view_id()")) @db.VarChar(15)
  code       String  @unique @db.VarChar(50)
  name       String  @db.VarChar(100)
  moduleCode String  @map("module_code") @db.VarChar(10)
  path       String  @db.VarChar(200)
  sortNo     Int     @default(0) @map("sort_no")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00ViewCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00ViewUpdatedBy", fields: [updatedBy], references: [id])

  roleViews Nx00RoleView[]

  @@index([moduleCode])
  @@index([isActive])
  @@map("nx00_view")
}

/// =======================================================
/// NX00 - RoleView
/// Table: nx00_role_view
/// =======================================================
model Nx00RoleView {
  id       String     @id @default(dbgenerated("gen_nx00_role_view_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId String     @map("tenant_id") @db.VarChar(15)
  tenant   Nx99Tenant @relation(fields: [tenantId], references: [id])
  roleId   String     @map("role_id") @db.VarChar(15)
  viewId   String     @map("view_id") @db.VarChar(15)

  /// 瀏覽（進入畫面、列表／明細）
  canRead         Boolean @default(true) @map("can_read")
  /// 新增
  canCreate       Boolean @default(false) @map("can_create")
  /// 修改
  canUpdate       Boolean @default(false) @map("can_update")
  /// 啟用／停用（狀態切換；DB 欄位仍為 can_delete）
  canToggleActive Boolean @default(false) @map("can_delete")
  /// 匯出
  canExport       Boolean @default(false) @map("can_export")

  isActive Boolean @default(true) @map("is_active")

  grantedAt DateTime  @default(now()) @map("granted_at")
  grantedBy String?   @map("granted_by") @db.VarChar(15)
  revokedAt DateTime? @map("revoked_at")
  revokedBy String?   @map("revoked_by") @db.VarChar(15)

  role Nx00Role @relation(fields: [roleId], references: [id])
  view Nx00View @relation(fields: [viewId], references: [id])

  grantedByUser Nx00User? @relation("Nx00RoleViewGrantedBy", fields: [grantedBy], references: [id])
  revokedByUser Nx00User? @relation("Nx00RoleViewRevokedBy", fields: [revokedBy], references: [id])

  @@unique([tenantId, roleId, viewId])
  @@index([tenantId])
  @@index([roleId])
  @@index([viewId])
  @@index([isActive])
  @@map("nx00_role_view")
}

/// =======================================================
/// NX00 - Country（docs/nx00_field.csv）
/// Table: nx00_country
/// =======================================================
model Nx00Country {
  id       String  @id @default(dbgenerated("gen_nx00_coun_id()")) @db.VarChar(15)
  /// 國家代碼，例：TWN、DEU、JPN
  code     String  @unique @db.VarChar(3)
  /// 國家名稱
  name     String  @db.VarChar(100)
  sortNo   Int     @default(0) @map("sort_no")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00CountryCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00CountryUpdatedBy", fields: [updatedBy], references: [id])

  partBrands Nx00PartBrand[]
  carBrands  Nx00CarBrand[]
  parts      Nx00Part[]

  @@index([isActive])
  @@map("nx00_country")
}

/// =======================================================
/// NX00 - Currency（docs/nx00_field.csv；ID 前綴 NX00CURR）
/// Table: nx00_currency
/// =======================================================
model Nx00Currency {
  id            String  @id @default(dbgenerated("gen_nx00_curr_id()")) @db.VarChar(15)
  /// 幣別代碼，例：TWD、EUR、JPY
  code          String  @unique @db.VarChar(3)
  name          String  @db.VarChar(100)
  symbol        String? @db.VarChar(5)
  decimalPlaces Int     @default(2) @map("decimal_places")
  sortNo        Int     @default(0) @map("sort_no")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00CurrencyCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00CurrencyUpdatedBy", fields: [updatedBy], references: [id])

  subscriptions Nx99Subscription[]

  @@index([isActive])
  @@map("nx00_currency")
}

/// =======================================================
/// NX00 - Part（docs/nx00_field.csv）
/// Table: nx00_part
/// =======================================================
model Nx00Part {
  /// [NX00]+[PART]+[7碼流水號]，EX : NX00PART0000001
  id          String            @id @default(dbgenerated("gen_nx00_part_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId    String            @map("tenant_id") @db.VarChar(15)
  tenant      Nx99Tenant        @relation(fields: [tenantId], references: [id])
  /// 編碼規則（外鍵 → nx00_brand_code_rule）
  codeRuleId  String            @map("code_rule_id") @db.VarChar(15)
  codeRule    Nx00BrandCodeRule @relation(fields: [codeRuleId], references: [id])
  /// 零件料號（系統組合；唯一性：同租戶 + 同料號 + 同產地）
  code        String            @db.VarChar(50)
  /// 零件名稱/品名
  name        String            @db.VarChar(200)
  isOem       Boolean           @default(true) @map("is_oem")
  secCode     String?           @map("sec_code") @db.VarChar(50)
  seg1        String?           @db.VarChar(10)
  seg2        String?           @db.VarChar(10)
  seg3        String?           @db.VarChar(10)
  seg4        String?           @db.VarChar(10)
  seg5        String?           @db.VarChar(10)
  countryId   String?           @map("country_id") @db.VarChar(15)
  country     Nx00Country?      @relation(fields: [countryId], references: [id])
  partBrandId String?           @map("part_brand_id") @db.VarChar(15)
  partBrand   Nx00PartBrand?    @relation(fields: [partBrandId], references: [id])
  /// A=專用型 / B=通用型 / C=組合型 / D=拆解型
  partType    String            @default("A") @map("type") @db.VarChar(1)
  partGroupId String?           @map("part_group_id") @db.VarChar(15)
  partGroup   Nx00PartGroup?    @relation(fields: [partGroupId], references: [id])
  spec        String?           @db.VarChar(200)
  uom         String            @default("pcs") @db.VarChar(10)
  isActive    Boolean           @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00PartCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartUpdatedBy", fields: [updatedBy], references: [id])

  relationsFrom Nx00PartRelation[] @relation("Nx00PartRelationFrom")
  relationsTo   Nx00PartRelation[] @relation("Nx00PartRelationTo")

  stockLedgers       Nx02StockLedger[]
  stockBalances      Nx02StockBalance[]
  partStockSettings  Nx02PartStockSetting[]
  shortages          Nx02Shortage[]
  stockTakeItems     Nx02StockTakeItem[]
  stockTransferItems Nx02StockTransferItem[]
  initItems          Nx02InitItem[]
  rfqItems           Nx01RfqItem[]

  @@unique([tenantId, code, countryId])
  @@index([tenantId])
  @@index([codeRuleId])
  @@index([partBrandId])
  @@index([countryId])
  @@index([partGroupId])
  @@index([isActive])
  @@map("nx00_part")
}

/// =======================================================
/// NX00 - Part brand（零件品牌，docs/nx00_field.csv）
/// Table: nx00_part_brand
/// =======================================================
model Nx00PartBrand {
  id        String       @id @default(dbgenerated("gen_nx00_pabr_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId  String       @map("tenant_id") @db.VarChar(15)
  tenant    Nx99Tenant   @relation(fields: [tenantId], references: [id])
  /// 零件品牌代碼（3 碼）
  code      String       @db.VarChar(3)
  name      String       @db.VarChar(100)
  /// 品牌國家
  countryId String?      @map("country_id") @db.VarChar(15)
  country   Nx00Country? @relation(fields: [countryId], references: [id])
  remark    String?      @db.VarChar(200)
  isActive  Boolean      @default(true) @map("is_active")
  sortNo    Int          @default(0) @map("sort_no")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00PartBrandCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartBrandUpdatedBy", fields: [updatedBy], references: [id])

  parts              Nx00Part[]
  brandCodeRules     Nx00BrandCodeRule[]
  stockTransferItems Nx02StockTransferItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([countryId])
  @@index([isActive])
  @@map("nx00_part_brand")
}

/// =======================================================
/// NX00 - Car brand（汽車品牌，docs/nx00_field.csv）
/// Table: nx00_car_brand
/// =======================================================
model Nx00CarBrand {
  id        String       @id @default(dbgenerated("gen_nx00_cabr_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId  String       @map("tenant_id") @db.VarChar(15)
  tenant    Nx99Tenant   @relation(fields: [tenantId], references: [id])
  code      String       @db.VarChar(30)
  name      String       @db.VarChar(100)
  countryId String?      @map("country_id") @db.VarChar(15)
  country   Nx00Country? @relation(fields: [countryId], references: [id])
  remark    String?      @db.VarChar(200)
  isActive  Boolean      @default(true) @map("is_active")
  sortNo    Int          @default(0) @map("sort_no")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00CarBrandCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00CarBrandUpdatedBy", fields: [updatedBy], references: [id])

