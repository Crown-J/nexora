model Nx99ProductModule {
  /// NX99 產品模組主檔 - 定義可銷售的 SKU
  id                 String   @id @default(dbgenerated("gen_nx99_prmo_id()")) @db.VarChar(15)
  code               String   @unique @db.VarChar(30)
  name               String   @db.VarChar(100)
  moduleLevel        String   @map("module_level") @db.VarChar(1)
  applicablePlanCode String   @map("applicable_plan_code") @db.VarChar(30)
  billingType        String   @map("billing_type") @db.VarChar(1)
  monthlyFee         Int      @map("monthly_fee")
  isBundleDefault    Boolean  @map("is_bundle_default")
  description        String?
  sortNo             Int      @map("sort_no")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  createdBy          String?  @map("created_by") @db.VarChar(15)
  updatedAt          DateTime @updatedAt @map("updated_at")
  updatedBy          String?  @map("updated_by") @db.VarChar(15)

  moduleMaps Nx99ProductModuleMap[]

  @@map("nx99_product_module")
}

/// =======================================================
/// NX99 - ProductModuleMap
/// Table: nx99_product_module_map
/// =======================================================
model Nx99ProductModuleMap {
  /// NX99 模組對照表 - 將 SKU 對應到程式碼模組 NX00~NX06
  id              String   @id @default(dbgenerated("gen_nx99_prmm_id()")) @db.VarChar(15)
  productModuleId String   @map("product_module_id") @db.VarChar(15)
  appModuleCode   String   @map("app_module_code") @db.VarChar(10)
  isRequired      Boolean  @default(true) @map("is_required")
  remark          String?  @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String?  @map("created_by") @db.VarChar(15)
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedBy       String?  @map("updated_by") @db.VarChar(15)

  productModule Nx99ProductModule @relation(fields: [productModuleId], references: [id])

  @@map("nx99_product_module_map")
}
