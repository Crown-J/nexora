// C:\nexora\packages\db-core\prisma\schema.prisma
// NEXORA / db-core schema
// - NX00 主檔欄位以 docs/nx00_field.csv 為準（Prisma 仍 camelCase；DB snake_case 用 @map）
// - Prisma 欄位 camelCase；DB 欄位 snake_case 用 @map 對應
// - 欄位說明：每個 scalar／關聯欄位上方使用 ///（Prisma doc）；PostgreSQL 以 migration COMMENT ON 寫入表／欄位備註（見 migrations/*_add_pg_comments_all）
// - ID 規則：VARCHAR(15) 由 DB DEFAULT gen_xxx_id() 產生
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

/// 連線由執行環境之 `DATABASE_URL`／`DIRECT_URL` 提供（見 `prisma.config.ts` 與 `packages/db-core/.env.example`）；本機預設為 Docker PostgreSQL（`infra/docker/docker-compose.yml`）。
/// Prisma ORM 7 不支援於此區塊宣告 `url`／`directUrl`。
datasource db {
  provider = "postgresql"
}

/// =======================================================
/// NX00 - User
/// Table: nx00_user
/// =======================================================
/// 對齊 docs/nx00_field.csv（LITE）
model Nx00User {
  id         String     @id @default(dbgenerated("gen_nx00_user_id()")) @db.VarChar(15)
  /// 租戶 ID（外鍵 → nx99_tenant）
  tenantId   String     @map("tenant_id") @db.VarChar(15)
  tenant     Nx99Tenant @relation(fields: [tenantId], references: [id])
  /// 員工主檔 ID（外鍵，PRO；表未於 CSV 定義時可僅存 ID）
  employeeId String?    @map("employee_id") @db.VarChar(15)

  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  displayName  String    @map("display_name") @db.VarChar(50)
  email        String?   @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  // self audit relations
  createdByUser Nx00User? @relation("Nx00UserCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00UserUpdatedBy", fields: [updatedBy], references: [id])

  createdUsers Nx00User[] @relation("Nx00UserCreatedBy")
  updatedUsers Nx00User[] @relation("Nx00UserUpdatedBy")

  // RBAC (UserRole / RoleView)
  userRoles Nx00UserRole[]

  /// 使用者可進出之倉庫／據點（nx00_user_warehouse）
  userWarehouses         Nx00UserWarehouse[]
  userWarehousesAssigned Nx00UserWarehouse[] @relation("Nx00UserWarehouseAssignedBy")

  // reverse relations (created/updated)
  rolesCreated     Nx00Role[]     @relation("Nx00RoleCreatedBy")
  rolesUpdated     Nx00Role[]     @relation("Nx00RoleUpdatedBy")
  viewsCreated     Nx00View[]     @relation("Nx00ViewCreatedBy")
  viewsUpdated     Nx00View[]     @relation("Nx00ViewUpdatedBy")
  roleViewsCreated Nx00RoleView[] @relation("Nx00RoleViewCreatedBy")
  roleViewsUpdated Nx00RoleView[] @relation("Nx00RoleViewUpdatedBy")

  partsCreated      Nx00Part[]      @relation("Nx00PartCreatedBy")
  partsUpdated      Nx00Part[]      @relation("Nx00PartUpdatedBy")
  partBrandsCreated Nx00PartBrand[] @relation("Nx00PartBrandCreatedBy")
  partBrandsUpdated Nx00PartBrand[] @relation("Nx00PartBrandUpdatedBy")
  carBrandsCreated  Nx00CarBrand[]  @relation("Nx00CarBrandCreatedBy")
  carBrandsUpdated  Nx00CarBrand[]  @relation("Nx00CarBrandUpdatedBy")
  partGroupsCreated Nx00PartGroup[] @relation("Nx00PartGroupCreatedBy")
  partGroupsUpdated Nx00PartGroup[] @relation("Nx00PartGroupUpdatedBy")
  warehousesCreated Nx00Warehouse[] @relation("Nx00WarehouseCreatedBy")
  warehousesUpdated Nx00Warehouse[] @relation("Nx00WarehouseUpdatedBy")
  locationsCreated  Nx00Location[]  @relation("Nx00LocationCreatedBy")
  locationsUpdated  Nx00Location[]  @relation("Nx00LocationUpdatedBy")
  partnersCreated   Nx00Partner[]   @relation("Nx00PartnerCreatedBy")
  partnersUpdated   Nx00Partner[]   @relation("Nx00PartnerUpdatedBy")

  // assignment/grant/revoke actors
  userRolesAssigned Nx00UserRole[] @relation("Nx00UserRoleAssignedBy")
  roleViewsGranted  Nx00RoleView[] @relation("Nx00RoleViewGrantedBy")
  roleViewsRevoked  Nx00RoleView[] @relation("Nx00RoleViewRevokedBy")

  // audit log actor
  auditLogs Nx00AuditLog[]

  bulletinsCreated      Nx00Bulletin[]      @relation("Nx00BulletinCreatedBy")
  bulletinsUpdated      Nx00Bulletin[]      @relation("Nx00BulletinUpdatedBy")
  calendarEventsCreated Nx00CalendarEvent[] @relation("Nx00CalendarEventCreatedBy")
  calendarEventsUpdated Nx00CalendarEvent[] @relation("Nx00CalendarEventUpdatedBy")

  countriesCreated      Nx00Country[]       @relation("Nx00CountryCreatedBy")
  countriesUpdated      Nx00Country[]       @relation("Nx00CountryUpdatedBy")
  currenciesCreated     Nx00Currency[]      @relation("Nx00CurrencyCreatedBy")
  currenciesUpdated     Nx00Currency[]      @relation("Nx00CurrencyUpdatedBy")
  brandCodeRolesCreated Nx00BrandCodeRole[] @relation("Nx00BrandCodeRoleCreatedBy")
  brandCodeRolesUpdated Nx00BrandCodeRole[] @relation("Nx00BrandCodeRoleUpdatedBy")
  partRelationsCreated  Nx00PartRelation[]  @relation("Nx00PartRelationCreatedBy")
  partRelationsUpdated  Nx00PartRelation[]  @relation("Nx00PartRelationUpdatedBy")

  @@index([tenantId])
  @@map("nx00_user")
}

/// =======================================================
/// NX00 - Role
/// Table: nx00_role
/// =======================================================
model Nx00Role {
  id          String  @id @default(dbgenerated("gen_nx00_role_id()")) @db.VarChar(15)
  code        String  @unique @db.VarChar(30)
  name        String  @db.VarChar(50)
  description String? @db.VarChar(200)
  isSystem    Boolean @default(false) @map("is_system")
  isActive    Boolean @default(true) @map("is_active")
  sortNo      Int     @default(0) @map("sort_no")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00RoleCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00RoleUpdatedBy", fields: [updatedBy], references: [id])

  userRoles Nx00UserRole[]
  roleViews Nx00RoleView[]

  @@map("nx00_role")
}

/// =======================================================
/// NX00 - UserRole
/// Table: nx00_user_role
/// =======================================================
model Nx00UserRole {
  id     String @id @default(dbgenerated("gen_nx00_user_role_id()")) @db.VarChar(15)
  userId String @map("user_id") @db.VarChar(15)
  roleId String @map("role_id") @db.VarChar(15)

  isPrimary  Boolean   @default(false) @map("is_primary")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by") @db.VarChar(15)
  revokedAt  DateTime? @map("revoked_at")
  isActive   Boolean   @default(true) @map("is_active")

  user           Nx00User  @relation(fields: [userId], references: [id])
  role           Nx00Role  @relation(fields: [roleId], references: [id])
  assignedByUser Nx00User? @relation("Nx00UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([isActive])
  @@map("nx00_user_role")
}

/// =======================================================
/// NX00 - UserWarehouse（使用者據點對應）
/// Table: nx00_user_warehouse
/// =======================================================
model Nx00UserWarehouse {
  id          String @id @default(dbgenerated("gen_nx00_user_warehouse_id()")) @db.VarChar(15)
  userId      String @map("user_id") @db.VarChar(15)
  warehouseId String @map("warehouse_id") @db.VarChar(15)

  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by") @db.VarChar(15)
  revokedAt  DateTime? @map("revoked_at")
  isActive   Boolean   @default(true) @map("is_active")

  user           Nx00User      @relation(fields: [userId], references: [id])
  warehouse      Nx00Warehouse @relation(fields: [warehouseId], references: [id])
  assignedByUser Nx00User?     @relation("Nx00UserWarehouseAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, warehouseId])
  @@index([userId])
  @@index([warehouseId])
  @@index([isActive])
  @@map("nx00_user_warehouse")
}

/// =======================================================
/// NX00 - View
/// Table: nx00_view
/// =======================================================
model Nx00View {
  id         String  @id @default(dbgenerated("gen_nx00_view_id()")) @db.VarChar(15)
  code       String  @unique @db.VarChar(50)
  name       String  @db.VarChar(100)
  moduleCode String  @map("module_code") @db.VarChar(10)
  path       String  @db.VarChar(200)
  sortNo     Int     @default(0) @map("sort_no")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00ViewCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00ViewUpdatedBy", fields: [updatedBy], references: [id])

  roleViews Nx00RoleView[]

  @@index([moduleCode])
  @@index([isActive])
  @@map("nx00_view")
}

/// =======================================================
/// NX00 - RoleView
/// Table: nx00_role_view
/// =======================================================
model Nx00RoleView {
  id     String @id @default(dbgenerated("gen_nx00_role_view_id()")) @db.VarChar(15)
  roleId String @map("role_id") @db.VarChar(15)
  viewId String @map("view_id") @db.VarChar(15)

  canRead   Boolean @default(true) @map("can_read")
  canCreate Boolean @default(false) @map("can_create")
  canUpdate Boolean @default(false) @map("can_update")
  canDelete Boolean @default(false) @map("can_delete")
  canExport Boolean @default(false) @map("can_export")

  isActive Boolean @default(true) @map("is_active")

  grantedAt DateTime  @default(now()) @map("granted_at")
  grantedBy String?   @map("granted_by") @db.VarChar(15)
  revokedAt DateTime? @map("revoked_at")
  revokedBy String?   @map("revoked_by") @db.VarChar(15)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  role Nx00Role @relation(fields: [roleId], references: [id])
  view Nx00View @relation(fields: [viewId], references: [id])

  grantedByUser Nx00User? @relation("Nx00RoleViewGrantedBy", fields: [grantedBy], references: [id])
  revokedByUser Nx00User? @relation("Nx00RoleViewRevokedBy", fields: [revokedBy], references: [id])

  createdByUser Nx00User? @relation("Nx00RoleViewCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00RoleViewUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([roleId, viewId])
  @@index([roleId])
  @@index([viewId])
  @@index([isActive])
  @@map("nx00_role_view")
}

/// =======================================================
/// NX00 - Country（docs/nx00_field.csv）
/// Table: nx00_country
/// =======================================================
model Nx00Country {
  id       String  @id @default(dbgenerated("gen_nx00_coun_id()")) @db.VarChar(15)
  /// 國家代碼，例：TWN、DEU、JPN
  code     String  @unique @db.VarChar(3)
  /// 國家名稱
  name     String  @db.VarChar(100)
  sortNo   Int     @default(0) @map("sort_no")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00CountryCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00CountryUpdatedBy", fields: [updatedBy], references: [id])

  partBrands Nx00PartBrand[]
  carBrands  Nx00CarBrand[]
  parts      Nx00Part[]

  @@index([isActive])
  @@map("nx00_country")
}

/// =======================================================
/// NX00 - Currency（docs/nx00_field.csv；ID 前綴 NX00CURR）
/// Table: nx00_currency
/// =======================================================
model Nx00Currency {
  id            String  @id @default(dbgenerated("gen_nx00_curr_id()")) @db.VarChar(15)
  /// 幣別代碼，例：TWD、EUR、JPY
  code          String  @unique @db.VarChar(3)
  name          String  @db.VarChar(100)
  symbol        String? @db.VarChar(5)
  decimalPlaces Int     @default(2) @map("decimal_places")
  sortNo        Int     @default(0) @map("sort_no")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00CurrencyCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00CurrencyUpdatedBy", fields: [updatedBy], references: [id])

  @@index([isActive])
  @@map("nx00_currency")
}

/// =======================================================
/// NX00 - Part（docs/nx00_field.csv）
/// Table: nx00_part
/// =======================================================
model Nx00Part {
  id          String         @id @default(dbgenerated("gen_nx00_part_id()")) @db.VarChar(15)
  /// 零件料號
  code        String         @db.VarChar(50)
  /// 零件名稱／品名
  name        String         @db.VarChar(200)
  isOem       Boolean        @default(true) @map("is_oem")
  /// 副廠料號
  secCode     String?        @map("sec_code") @db.VarChar(50)
  seg1        String?        @db.VarChar(10)
  seg2        String?        @db.VarChar(10)
  seg3        String?        @db.VarChar(10)
  seg4        String?        @db.VarChar(10)
  seg5        String?        @db.VarChar(10)
  /// 產地
  countryId   String?        @map("country_id") @db.VarChar(15)
  country     Nx00Country?   @relation(fields: [countryId], references: [id])
  partBrandId String?        @map("part_brand_id") @db.VarChar(15)
  /// A=專用型 / B=通用型 / C=組合型 / D=拆解型（預設 A）
  partType    String         @default("A") @map("type") @db.VarChar(1)
  /// 零件種類
  partGroupId String?        @map("part_group_id") @db.VarChar(15)
  partGroup   Nx00PartGroup? @relation(fields: [partGroupId], references: [id])
  spec        String?        @db.VarChar(200)
  uom         String         @default("pcs") @db.VarChar(10)
  isActive    Boolean        @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  partBrand Nx00PartBrand? @relation(fields: [partBrandId], references: [id])

  createdByUser Nx00User? @relation("Nx00PartCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartUpdatedBy", fields: [updatedBy], references: [id])

  rfqItems       Nx01RfqItem[]
  poItems        Nx01PoItem[]
  quoteItems     Nx03QuoteItem[]
  soItems        Nx03SoItem[]
  relationsFrom  Nx00PartRelation[]  @relation("Nx00PartRelationFrom")
  relationsTo    Nx00PartRelation[]  @relation("Nx00PartRelationTo")
  stockBalances  Nx02StockBalance[]
  stockLedgers   Nx02StockLedger[]
  stockTakeItems Nx02StockTakeItem[]

  @@unique([code])
  @@index([partBrandId])
  @@index([countryId])
  @@index([partGroupId])
  @@index([isActive])
  @@map("nx00_part")
}

/// =======================================================
/// NX00 - Part brand（零件品牌，docs/nx00_field.csv）
/// Table: nx00_part_brand
/// =======================================================
model Nx00PartBrand {
  id        String       @id @default(dbgenerated("gen_nx00_pabr_id()")) @db.VarChar(15)
  /// 設計 LITE 建議 3 碼；匯入資料可能較長故欄寬 30
  code      String       @unique @db.VarChar(30)
  name      String       @db.VarChar(100)
  /// 品牌國家
  countryId String?      @map("country_id") @db.VarChar(15)
  country   Nx00Country? @relation(fields: [countryId], references: [id])
  remark    String?      @db.VarChar(200)
  isActive  Boolean      @default(true) @map("is_active")
  sortNo    Int          @default(0) @map("sort_no")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00PartBrandCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartBrandUpdatedBy", fields: [updatedBy], references: [id])

  parts         Nx00Part[]
  brandCodeRole Nx00BrandCodeRole?
  quoteItems    Nx03QuoteItem[]
  soItems       Nx03SoItem[]

  @@index([countryId])
  @@index([isActive])
  @@map("nx00_part_brand")
}

/// =======================================================
/// NX00 - Car brand（汽車品牌，docs/nx00_field.csv）
/// Table: nx00_car_brand
/// =======================================================
model Nx00CarBrand {
  id        String       @id @default(dbgenerated("gen_nx00_cabr_id()")) @db.VarChar(15)
  code      String       @unique @db.VarChar(30)
  name      String       @db.VarChar(100)
  countryId String?      @map("country_id") @db.VarChar(15)
  country   Nx00Country? @relation(fields: [countryId], references: [id])
  remark    String?      @db.VarChar(200)
  isActive  Boolean      @default(true) @map("is_active")
  sortNo    Int          @default(0) @map("sort_no")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00CarBrandCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00CarBrandUpdatedBy", fields: [updatedBy], references: [id])

  @@index([countryId])
  @@index([isActive])
  @@map("nx00_car_brand")
}

/// =======================================================
/// NX00 - Part group（零件族群／種類，docs/nx00_field.csv）
/// Table: nx00_part_group
/// =======================================================
model Nx00PartGroup {
  id       String  @id @default(dbgenerated("gen_nx00_pagr_id()")) @db.VarChar(15)
  code     String  @unique @db.VarChar(30)
  name     String  @db.VarChar(100)
  sortNo   Int     @default(0) @map("sort_no")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00PartGroupCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartGroupUpdatedBy", fields: [updatedBy], references: [id])

  parts Nx00Part[]

  @@index([isActive])
  @@map("nx00_part_group")
}

/// =======================================================
/// NX00 - Brand code role（料號規則，docs/nx00_field.csv）
/// Table: nx00_brand_code_role
/// =======================================================
model Nx00BrandCodeRole {
  id          String        @id @default(dbgenerated("gen_nx00_bcor_id()")) @db.VarChar(15)
  partBrandId String        @unique @map("part_brand_id") @db.VarChar(15)
  partBrand   Nx00PartBrand @relation(fields: [partBrandId], references: [id])
  seg1Limit   Int           @default(0) @map("seg1")
  seg2Limit   Int           @default(0) @map("seg2")
  seg3Limit   Int           @default(0) @map("seg3")
  seg4Limit   Int           @default(0) @map("seg4")
  seg5Limit   Int           @default(0) @map("seg5")
  /// 料號組合格式
  codeFormat  String        @map("code_format") @db.VarChar(20)
  /// 料號排列順序，例：12345、23145
  brandSort   String        @map("brand_sort") @db.VarChar(5)
  isActive    Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00BrandCodeRoleCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00BrandCodeRoleUpdatedBy", fields: [updatedBy], references: [id])

  @@index([isActive])
  @@map("nx00_brand_code_role")
}

/// =======================================================
/// NX00 - Part relation（零件關聯，docs/nx00_field.csv）
/// Table: nx00_part_relation
/// =======================================================
model Nx00PartRelation {
  id           String  @id @default(dbgenerated("gen_nx00_pare_id()")) @db.VarChar(15)
  partIdFrom   String  @map("part_id_from") @db.VarChar(15)
  partIdTo     String  @map("part_id_to") @db.VarChar(15)
  /// S=改號 / R=同款 / C=改版換周邊 / B=組合包 / F=拆解包
  relationType String  @map("relation_type") @db.VarChar(1)
  remark       String? @db.VarChar(200)
  sortNo       Int     @default(0) @map("sort_no")
  isActive     Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  partFrom Nx00Part @relation("Nx00PartRelationFrom", fields: [partIdFrom], references: [id])
  partTo   Nx00Part @relation("Nx00PartRelationTo", fields: [partIdTo], references: [id])

  createdByUser Nx00User? @relation("Nx00PartRelationCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartRelationUpdatedBy", fields: [updatedBy], references: [id])

  @@index([partIdFrom])
  @@index([partIdTo])
  @@index([isActive])
  @@map("nx00_part_relation")
}

/// =======================================================
/// NX00 - Warehouse
/// Table: nx00_warehouse
/// =======================================================
model Nx00Warehouse {
  id       String  @id @default(dbgenerated("gen_nx00_warehouse_id()")) @db.VarChar(15)
  code     String  @unique @db.VarChar(10)
  name     String  @db.VarChar(100)
  remark   String? @db.VarChar(200)
  sortNo   Int     @default(0) @map("sort_no")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00WarehouseCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00WarehouseUpdatedBy", fields: [updatedBy], references: [id])

  locations          Nx00Location[]
  userWarehouses     Nx00UserWarehouse[]
  poItems            Nx01PoItem[]
  soItems            Nx03SoItem[]
  stockBalances      Nx02StockBalance[]
  stockLedgers       Nx02StockLedger[]
  stockTakes         Nx02StockTake[]
  stockTakeLineItems Nx02StockTakeItem[]
  salesOrders        Nx03So[]

  @@index([isActive])
  @@map("nx00_warehouse")
}

/// =======================================================
/// NX00 - Location
/// Table: nx00_location
/// =======================================================
model Nx00Location {
  id          String  @id @default(dbgenerated("gen_nx00_location_id()")) @db.VarChar(15)
  warehouseId String  @map("warehouse_id") @db.VarChar(15)
  code        String  @db.VarChar(30)
  name        String? @db.VarChar(100)
  zone        String? @db.VarChar(20)
  rack        String? @db.VarChar(20)
  levelNo     Int?    @map("level_no")
  binNo       String? @map("bin_no") @db.VarChar(20)
  remark      String? @db.VarChar(200)
  sortNo      Int     @default(0) @map("sort_no")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  warehouse Nx00Warehouse @relation(fields: [warehouseId], references: [id])

  createdByUser Nx00User? @relation("Nx00LocationCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00LocationUpdatedBy", fields: [updatedBy], references: [id])

  poItems        Nx01PoItem[]
  soItems        Nx03SoItem[]
  stockBalances  Nx02StockBalance[]
  stockTakeItems Nx02StockTakeItem[]
  stockLedgers   Nx02StockLedger[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([isActive])
  @@map("nx00_location")
}

/// =======================================================
/// NX00 - Partner
/// Table: nx00_partner
/// =======================================================
model Nx00Partner {
  id          String  @id @default(dbgenerated("gen_nx00_partner_id()")) @db.VarChar(15)
  code        String  @unique @db.VarChar(30)
  name        String  @db.VarChar(120)
  /// CUST=客戶 / SUP=供應商 / BOTH=皆是（docs/nx00_field.csv）
  partnerType String  @default("BOTH") @map("partner_type") @db.VarChar(10)
  contactName String? @map("contact_name") @db.VarChar(50)
  phone       String? @db.VarChar(30)
  mobile      String? @db.VarChar(30)
  email       String? @db.VarChar(100)
  address     String? @db.VarChar(200)
  remark      String? @db.VarChar(200)
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  createdByUser Nx00User? @relation("Nx00PartnerCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User? @relation("Nx00PartnerUpdatedBy", fields: [updatedBy], references: [id])

  rfqs        Nx01Rfq[]
  pos         Nx01Po[]
  quotes      Nx03Quote[]
  salesOrders Nx03So[]
  arLedgers   Nx04ArLedger[]
  apLedgers   Nx04ApLedger[]
  paylogs     Nx04Paylog[]

  @@index([isActive])
  @@index([partnerType])
  @@map("nx00_partner")
}

/// =======================================================
/// NX00 - AuditLog
/// Table: nx00_audit_log
/// =======================================================
model Nx00AuditLog {
  id          String   @id @default(dbgenerated("gen_nx00_audit_log_id()")) @db.VarChar(15)
  occurredAt  DateTime @default(now()) @map("occurred_at")
  actorUserId String   @map("actor_user_id") @db.VarChar(15)

  moduleCode  String @map("module_code") @db.VarChar(10)
  action      String @db.VarChar(20)
  entityTable String @map("entity_table") @db.VarChar(50)

  entityId   String? @map("entity_id") @db.VarChar(20)
  entityCode String? @map("entity_code") @db.VarChar(50)
  summary    String? @db.VarChar(200)

  beforeData Json? @map("before_data")
  afterData  Json? @map("after_data")

  ipAddr    String? @map("ip_addr") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(200)

  actorUser Nx00User @relation(fields: [actorUserId], references: [id])

  @@index([occurredAt])
  @@index([actorUserId])
  @@index([moduleCode])
  @@index([entityTable])
  @@map("nx00_audit_log")
}

/// =======================================================
/// NX00 - Bulletin（首頁公告）
/// Table: nx00_bulletin
/// =======================================================
model Nx00Bulletin {
  id           String    @id @default(dbgenerated("gen_nx00_bull_id()")) @db.VarChar(15)
  /// 租戶（→ nx99_tenant）
  tenantId     String    @map("tenant_id") @db.VarChar(15)
  title        String    @db.VarChar(100)
  /// 副標題（UI 延伸欄位）
  subtitle     String?   @db.VarChar(200)
  content      String?   @db.Text
  /// S=SYSTEM / C=COMPANY / R=REMIND
  scopeType    String    @map("type") @db.VarChar(1)
  isPinned     Boolean   @default(false) @map("is_pinned")
  expiredAt    DateTime? @map("expired_at")
  isActive     Boolean   @default(true) @map("is_active")
  /// UI 標籤：important | normal | update
  displayBadge String?   @map("display_badge") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  tenant        Nx99Tenant @relation(fields: [tenantId], references: [id])
  createdByUser Nx00User?  @relation("Nx00BulletinCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User?  @relation("Nx00BulletinUpdatedBy", fields: [updatedBy], references: [id])

  @@index([tenantId])
  @@index([scopeType])
  @@index([isActive])
  @@map("nx00_bulletin")
}

/// =======================================================
/// NX00 - CalendarEvent（首頁行事曆）
/// Table: nx00_calendar_event
/// =======================================================
model Nx00CalendarEvent {
  id        String   @id @default(dbgenerated("gen_nx00_caev_id()")) @db.VarChar(15)
  tenantId  String   @map("tenant_id") @db.VarChar(15)
  title     String   @db.VarChar(100)
  subtitle  String?  @db.VarChar(200)
  content   String?  @db.Text
  /// S=SYSTEM / C=COMPANY / R=REMIND
  scopeType String   @map("type") @db.VarChar(1)
  /// UI 分類：meeting | delivery | visit | other
  eventKind String   @map("event_kind") @db.VarChar(20)
  dateStart DateTime @map("date_start")
  dateEnd   DateTime @map("date_end")
  isAllDay  Boolean  @default(false) @map("is_all_day")
  location  String?  @db.VarChar(200)
  orderType String?  @map("order_type") @db.VarChar(2)
  orderId   String?  @map("order_id") @db.VarChar(15)
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  tenant        Nx99Tenant @relation(fields: [tenantId], references: [id])
  createdByUser Nx00User?  @relation("Nx00CalendarEventCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User?  @relation("Nx00CalendarEventUpdatedBy", fields: [updatedBy], references: [id])

  @@index([tenantId])
  @@index([dateStart])
  @@index([isActive])
  @@map("nx00_calendar_event")
}

/// =======================================================
/// NX99 - Tenant
/// Table: nx99_tenant
/// =======================================================
model Nx99Tenant {
  /// NX99 租戶主檔 - 每間公司一筆，作為多租戶隔離根節點
  /// 主鍵（系統產生）
  id        String   @id @default(dbgenerated("gen_nx99_tant_id()")) @db.VarChar(15)
  /// 租戶代碼（唯一）
  code      String   @unique @db.VarChar(30)
  /// 租戶名稱
  name      String   @db.VarChar(100)
  /// 租戶英文名稱（頂欄等顯示）
  nameEn    String?  @map("name_en") @db.VarChar(200)
  /// 狀態（單碼）
  status    String   @db.VarChar(1)
  /// 備註
  remark    String?  @db.VarChar(200)
  /// 排序號
  sortNo    Int      @map("sort_no")
  /// 是否啟用
  isActive  Boolean  @map("is_active")
  /// 建立時間
  createdAt DateTime @default(now()) @map("created_at")
  /// 建立者（使用者 id，可空）
  createdBy String?  @map("created_by") @db.VarChar(15)
  /// 最後更新時間
  updatedAt DateTime @updatedAt @map("updated_at")
  /// 最後更新者（使用者 id，可空）
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  subscriptions   Nx99Subscription[]
  users           Nx00User[]
  rfqs            Nx01Rfq[]
  rfqItems        Nx01RfqItem[]
  pos             Nx01Po[]
  poItems         Nx01PoItem[]
  quotes          Nx03Quote[]
  quoteItems      Nx03QuoteItem[]
  salesOrders     Nx03So[]
  salesOrderItems Nx03SoItem[]
  stockBalances   Nx02StockBalance[]
  stockLedgers    Nx02StockLedger[]

  bulletins      Nx00Bulletin[]
  calendarEvents Nx00CalendarEvent[]

  @@map("nx99_tenant")
}

/// =======================================================
/// NX01 - RFQ (Header)
/// Table: nx01_rfq
/// =======================================================
model Nx01Rfq {
  /// NX01 詢價單表頭 - 記錄供應商詢價主檔，支援後續轉進貨單
  id           String    @id @default(dbgenerated("gen_nx01_rfqo_id()")) @db.VarChar(15)
  tenantId     String?   @map("tenant_id") @db.VarChar(15)
  docNo        String    @unique @map("doc_no") @db.VarChar(15)
  /// 單號規則：[R]+[年月]+[倉別]+[5碼流水號]，EX：R-202602-Z01-00001
  rfqDate      DateTime  @map("rfq_date") @db.Date
  supplierId   String    @map("supplier_id") @db.VarChar(15)
  contactName  String?   @map("contact_name") @db.VarChar(50)
  contactPhone String?   @map("contact_phone") @db.VarChar(30)
  currency     String    @default("TWD") @db.VarChar(10)
  status       String    @default("D") @db.VarChar(20)
  /// 單據狀態：(D=DRAFT, S=SENT, R=REPLIED, C=CLOSED, V=VOID)
  remark       String?   @db.VarChar(200)
  createdAt    DateTime  @default(now()) @map("created_at")
  createdBy    String?   @map("created_by") @db.VarChar(15)
  updatedAt    DateTime  @updatedAt @map("updated_at")
  updatedBy    String?   @map("updated_by") @db.VarChar(15)
  voidedAt     DateTime? @map("voided_at")
  voidedBy     String?   @map("voided_by") @db.VarChar(15)

  tenant   Nx99Tenant?   @relation(fields: [tenantId], references: [id])
  supplier Nx00Partner   @relation(fields: [supplierId], references: [id])
  items    Nx01RfqItem[]
  quotes   Nx03Quote[]

  @@map("nx01_rfq")
}

/// =======================================================
/// NX01 - RFQ Item
/// Table: nx01_rfq_item
/// =======================================================
model Nx01RfqItem {
  /// NX01 詢價單明細 - 含料號快照與供應商回覆資訊，支援部分或完整轉單
  id           String   @id @default(dbgenerated("gen_nx01_rfit_id()")) @db.VarChar(15)
  tenantId     String?  @map("tenant_id") @db.VarChar(15)
  rfqId        String   @map("rfq_id") @db.VarChar(15)
  lineNo       Int      @map("line_no")
  /// 明細排序號（1,2,3...）
  partId       String   @map("part_id") @db.VarChar(15)
  /// → nx00_part
  partNo       String   @map("part_no") @db.VarChar(50)
  /// 料號快照
  partName     String   @map("part_name") @db.VarChar(200)
  /// 零件名稱快照
  qty          Decimal  @db.Decimal(14, 4)
  unitPrice    Decimal? @map("unit_price") @db.Decimal(14, 4)
  /// 供應商回覆單價（未回覆可空）
  currency     String   @default("TWD") @db.VarChar(10)
  leadTimeDays Int?     @map("lead_time_days")
  /// 交期（天數，可空）
  status       String   @default("P") @db.VarChar(20)
  /// 狀態：(P=PENDING, R=REPLIED, S=SELECTED, C=REJECTED)
  remark       String?  @db.VarChar(200)
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?  @map("created_by") @db.VarChar(15)
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedBy    String?  @map("updated_by") @db.VarChar(15)

  tenant     Nx99Tenant?     @relation(fields: [tenantId], references: [id])
  rfq        Nx01Rfq         @relation(fields: [rfqId], references: [id])
  part       Nx00Part        @relation(fields: [partId], references: [id])
  quoteItems Nx03QuoteItem[]

  @@map("nx01_rfq_item")
}

/// =======================================================
/// NX01 - PO (Header)
/// Table: nx01_po
/// =======================================================
model Nx01Po {
  /// NX01 進貨單表頭 - 過帳後產生庫存異動與應付帳款
  id          String    @id @default(dbgenerated("gen_nx01_poht_id()")) @db.VarChar(15)
  tenantId    String?   @map("tenant_id") @db.VarChar(15)
  docNo       String    @unique @map("doc_no") @db.VarChar(15)
  /// 單號規則：[I]+[年月]+[倉別]+[5碼流水號]，EX：I-202602-Z01-00001
  poDate      DateTime  @map("po_date") @db.Date
  supplierId  String    @map("supplier_id") @db.VarChar(15)
  rfqId       String?   @map("rfq_id") @db.VarChar(15)
  currency    String    @default("TWD") @db.VarChar(10)
  subtotal    Decimal   @default(0) @db.Decimal(14, 2)
  taxAmount   Decimal   @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalAmount Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2)
  status      String    @default("D") @db.VarChar(1)
  /// 單據狀態：(D=DRAFT, P=POSTED, C=CANCELED)
  postedAt    DateTime? @map("posted_at")
  postedBy    String?   @map("posted_by") @db.VarChar(15)
  remark      String?   @db.VarChar(200)
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String?   @map("created_by") @db.VarChar(15)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by") @db.VarChar(15)
  voidedAt    DateTime? @map("voided_at")
  voidedBy    String?   @map("voided_by") @db.VarChar(15)

  tenant   Nx99Tenant?  @relation(fields: [tenantId], references: [id])
  supplier Nx00Partner  @relation(fields: [supplierId], references: [id])
  items    Nx01PoItem[]

  @@map("nx01_po")
}

/// =======================================================
/// NX01 - PO Item
/// Table: nx01_po_item
/// =======================================================
model Nx01PoItem {
  /// NX01 進貨單明細 - 過帳時寫入庫存異動台帳並更新庫存餘額
  id          String   @id @default(dbgenerated("gen_nx01_poit_id()")) @db.VarChar(15)
  tenantId    String?  @map("tenant_id") @db.VarChar(15)
  poId        String   @map("po_id") @db.VarChar(15)
  lineNo      Int      @map("line_no")
  /// 明細行號（1,2,3…）
  partId      String   @map("part_id") @db.VarChar(15)
  /// → nx00_part
  partNo      String   @map("part_no") @db.VarChar(50)
  /// 料號快照
  partName    String   @map("part_name") @db.VarChar(200)
  /// 零件名稱快照
  warehouseId String   @map("warehouse_id") @db.VarChar(15)
  /// → nx00_warehouse
  locationId  String?  @map("location_id") @db.VarChar(15)
  /// → nx00_location（LITE 先要求必填，此處保留 nullable）
  qty         Decimal  @db.Decimal(14, 4)
  unitCost    Decimal  @map("unit_cost") @db.Decimal(14, 4)
  lineAmount  Decimal  @map("line_amount") @db.Decimal(14, 4)
  /// qty * unit_cost
  remark      String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by") @db.VarChar(15)
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by") @db.VarChar(15)

  tenant    Nx99Tenant?   @relation(fields: [tenantId], references: [id])
  po        Nx01Po        @relation(fields: [poId], references: [id])
  part      Nx00Part      @relation(fields: [partId], references: [id])
  warehouse Nx00Warehouse @relation(fields: [warehouseId], references: [id])
  location  Nx00Location? @relation(fields: [locationId], references: [id])

  @@map("nx01_po_item")
}

/// =======================================================
/// NX03 - Quote（對客報價）
/// Table: nx03_quote
/// =======================================================
model Nx03Quote {
  id        String   @id @default(dbgenerated("gen_nx03_qthd_id()")) @db.VarChar(15)
  tenantId  String   @map("tenant_id") @db.VarChar(15)
  docNo     String   @unique @map("doc_no") @db.VarChar(15)
  quoteDate DateTime @map("quote_date") @db.Date

  customerId   String  @map("customer_id") @db.VarChar(15)
  contactName  String? @map("contact_name") @db.VarChar(50)
  contactPhone String? @map("contact_phone") @db.VarChar(30)
  rfqId        String? @map("rfq_id") @db.VarChar(15)

  currency    String    @default("TWD") @map("currency") @db.VarChar(10)
  status      String    @default("D") @map("status") @db.VarChar(1)
  validUntil  DateTime? @map("valid_until") @db.Date
  subtotal    Decimal   @default(0) @map("subtotal") @db.Decimal(14, 2)
  taxAmount   Decimal   @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalAmount Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2)
  remark      String?   @map("remark") @db.VarChar(200)

  voidedAt DateTime? @map("voided_at")
  voidedBy String?   @map("voided_by") @db.VarChar(15)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  tenant      Nx99Tenant      @relation(fields: [tenantId], references: [id])
  customer    Nx00Partner     @relation(fields: [customerId], references: [id])
  rfq         Nx01Rfq?        @relation(fields: [rfqId], references: [id])
  items       Nx03QuoteItem[]
  salesOrders Nx03So[]

  @@map("nx03_quote")
}

/// =======================================================
/// NX03 - Quote Item
/// Table: nx03_quote_item
/// =======================================================
model Nx03QuoteItem {
  id       String @id @default(dbgenerated("gen_nx03_qtit_id()")) @db.VarChar(15)
  tenantId String @map("tenant_id") @db.VarChar(15)

  quoteId String @map("quote_id") @db.VarChar(15)
  lineNo  Int    @map("line_no")

  rfqItemId String? @map("rfq_item_id") @db.VarChar(15)

  partId      String  @map("part_id") @db.VarChar(15)
  partNo      String  @map("part_no") @db.VarChar(50)
  partName    String  @map("part_name") @db.VarChar(200)
  partBrandId String? @map("part_brand_id") @db.VarChar(15)

  qty             Decimal @db.Decimal(14, 4)
  unitPrice       Decimal @default(0) @map("unit_price") @db.Decimal(14, 4)
  discountRate    Decimal @default(0) @map("discount_rate") @db.Decimal(6, 4)
  lineAmount      Decimal @default(0) @map("line_amount") @db.Decimal(14, 2)
  estUnitCost     Decimal @default(0) @map("est_unit_cost") @db.Decimal(14, 4)
  estMarginAmount Decimal @default(0) @map("est_margin_amount") @db.Decimal(14, 2)

  /// 由 RFQ 流程保留之成本／交期快照（與 unit_price 並存）
  unitCostSnapshot  Decimal? @map("unit_cost_snapshot") @db.Decimal(14, 4)
  unitPriceSnapshot Decimal? @map("unit_price_snapshot") @db.Decimal(14, 4)
  markupType        String?  @map("markup_type") @db.VarChar(1)
  markupValue       Decimal? @map("markup_value") @db.Decimal(14, 4)

  currency     String @default("TWD") @map("currency") @db.VarChar(10)
  leadTimeDays Int?   @map("lead_time_days")

  remark String? @map("remark") @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(15)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(15)

  tenant    Nx99Tenant     @relation(fields: [tenantId], references: [id])
  quote     Nx03Quote      @relation(fields: [quoteId], references: [id])
  rfqItem   Nx01RfqItem?   @relation(fields: [rfqItemId], references: [id])
  part      Nx00Part       @relation(fields: [partId], references: [id])
  partBrand Nx00PartBrand? @relation(fields: [partBrandId], references: [id])
  soItems   Nx03SoItem[]

  @@map("nx03_quote_item")
}

/// =======================================================
/// NX03 - Sales Order（銷貨單）
/// Table: nx03_so
/// =======================================================
model Nx03So {
