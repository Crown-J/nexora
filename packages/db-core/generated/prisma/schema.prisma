  warehouse     Nx00Warehouse @relation(fields: [warehouseId], references: [id])
  createdByUser Nx00User?     @relation("Nx02InitCreatedBy", fields: [createdBy], references: [id])
  updatedByUser Nx00User?     @relation("Nx02InitUpdatedBy", fields: [updatedBy], references: [id])
